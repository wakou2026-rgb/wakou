APP_ENV=development

# Database (Docker Compose 預設使用 MySQL)
DATABASE_URL=mysql+pymysql://wakou:wakou_password@db:3306/wakou

# JWT
JWT_SECRET_KEY=replace-me-with-a-real-secret
JWT_ALGORITHM=HS256

# MySQL container settings (used by db service in docker-compose)
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=wakou
MYSQL_USER=wakou
MYSQL_PASSWORD=wakou_password

# NVIDIA NIM Kimi 2.5 API Key
NVIDIA_API_KEY=nvapi-your-key-here

# Kimi provider selection: auto | nvidia | moonshot
KIMI_PROVIDER=auto

# Moonshot Platform API Key (required when KIMI_PROVIDER=moonshot)
MOONSHOT_API_KEY=sk-your-key-here
