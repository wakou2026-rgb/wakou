APP_ENV=development

# Database (Docker Compose 預設使用 MySQL)
DATABASE_URL=mysql+pymysql://wakou:wakou_password@db:3306/wakou

# JWT
JWT_SECRET_KEY=replace-me-with-a-real-secret
JWT_ALGORITHM=HS256

# MySQL container settings (used by db service in docker-compose)
MYSQL_ROOT_PASSWORD=root_password
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_DATABASE=wakou
MYSQL_USER=wakou
MYSQL_PASSWORD=wakou_password

# NVIDIA NIM Kimi 2.5 API Key
NVIDIA_API_KEY=nvapi-your-key-here

# Kimi provider selection: auto | nvidia | moonshot
KIMI_PROVIDER=auto

# Moonshot Platform API Key (required when KIMI_PROVIDER=moonshot)
MOONSHOT_API_KEY=sk-your-key-here

# Mail / Notification (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_APP_PASSWORD=your-16-char-app-password
MAIL_FROM=your-gmail@gmail.com
NOTIFY_TO_EMAIL=your-gmail@gmail.com
FRONTEND_BASE_URL=http://localhost
ADMIN_BASE_URL=http://localhost/admin
SMTP_TIMEOUT_SECONDS=12

# Register verification code policy
REGISTER_CODE_TTL_SECONDS=600
REGISTER_CODE_COOLDOWN_SECONDS=60
REGISTER_CODE_MAX_ATTEMPTS=5
AUTH_EMAIL_DEV_EXPOSE_CODE=1

# Inquiry reminder policy
INQUIRY_REMINDER_HOURS=6
INQUIRY_REMINDER_SCAN_SECONDS=600
