APP_ENV=development

MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=wakou
MYSQL_PASSWORD=wakou_password
MYSQL_DATABASE=wakou

JWT_SECRET=replace-me
JWT_ALGORITHM=HS256

# NVIDIA NIM Kimi 2.5 API Key
NVIDIA_API_KEY=nvapi-your-key-here

# Kimi provider selection: auto | nvidia | moonshot
KIMI_PROVIDER=auto

# Moonshot Platform API Key (required when KIMI_PROVIDER=moonshot)
MOONSHOT_API_KEY=sk-your-key-here
