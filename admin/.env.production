# 线上环境平台打包路径（Render static site root）
VITE_PUBLIC_PATH = /

# 线上环境路由历史模式 (HTML5 with root base)
VITE_ROUTER_HISTORY = "h5,/"

# 是否在打包时使用cdn替换本地库 替换 true 不替换 false
VITE_CDN = false

# 压缩
VITE_COMPRESSION = "none"

# API base (override in Render env when needed)
VITE_API_BASE_URL = https://wakou.onrender.com/api
